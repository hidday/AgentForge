PORT=3100
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_orchestrator?schema=public

# mock | real
AGENT_RUNTIME_MODE=mock

# CLI commands (used in real mode only)
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_ARGS_BASE=--print --output-format stream-json --verbose --dangerously-skip-permissions
# Model passed to the Claude Code CLI via --model. Use the dashed model ID
# (e.g. claude-opus-4-8) -- a dotted form like claude-opus-4.8 is invalid.
CLAUDE_CODE_MODEL=claude-opus-4-8
CODEX_COMMAND=codex
CODEX_ARGS_BASE=exec -
CURSOR_COMMAND=agent
CURSOR_ARGS_BASE=--print --output-format json --force --trust
CURSOR_MODEL=claude-4.7-opus

# Agent subprocess timeout in milliseconds (planners, reviewers, etc.)
AGENT_TIMEOUT_MS=120000

# Executor-specific timeout -- implementation needs more time (default 60m)
# EXECUTOR_TIMEOUT_MS=3600000

# Root directory containing all managed repositories.
# All non-absolute `directory` values in repos.config.json are resolved relative
# to this path. Set this to the parent folder where you keep checkouts.
REPOS_ROOT_PATH=./workspace

# Path to the repo configuration file.
# A committed template lives at foundry/repos.config.example.json. Copy it to
# repos.config.json and edit for your machine; the loader falls back to the
# example automatically if the live file is missing.
REPOS_CONFIG_PATH=./repos.config.json

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Linear API key (optional -- falls back to mock client when unset)
# LINEAR_API_KEY=lin_api_xxxx

# GitHub personal access token (optional -- falls back to mock client when unset)
# GITHUB_TOKEN=ghp_xxxx

# Discover pending Linear issues on server startup (requires LINEAR_API_KEY)
# SYNC_ON_STARTUP=false
