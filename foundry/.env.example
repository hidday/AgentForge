PORT=3100
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_orchestrator?schema=public

# mock | real
AGENT_RUNTIME_MODE=mock

# CLI commands (used in real mode only)
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_ARGS_BASE=--print --output-format stream-json --verbose --dangerously-skip-permissions
CODEX_COMMAND=codex
CODEX_ARGS_BASE=--approval-mode full-auto -q
CURSOR_COMMAND=agent
CURSOR_ARGS_BASE=--print --output-format json --force --trust
CURSOR_MODEL=claude-4.7-opus

# Agent subprocess timeout in milliseconds
AGENT_TIMEOUT_MS=120000

# Root directory containing all managed repositories.
# All repos in repos.config.json are resolved relative to this path
# (unless the directory value is an absolute path).
REPOS_ROOT_PATH=/Users/hiddaysaban/Code

# Path to the repo configuration file
REPOS_CONFIG_PATH=./repos.config.json

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Linear API key (optional -- falls back to mock client when unset)
# LINEAR_API_KEY=lin_api_xxxx

# GitHub personal access token (optional -- falls back to mock client when unset)
# GITHUB_TOKEN=ghp_xxxx

# Discover pending Linear issues on server startup (requires LINEAR_API_KEY)
# SYNC_ON_STARTUP=false
