generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RunState {
  Todo
  Planning
  PlanReview
  PlanRevision
  AwaitingPlanApproval
  Implementing
  AIReview
  AddressingReview
  ReadyForHumanReview
  Done
  AIBlocked
  HumanClarificationNeeded
  Failed
}

enum ArtifactType {
  Plan
  PlanReview
  PlanRevision
  ExecutionReport
  Review
  Remediation
  PlannerTranscript
  PlanReviewerTranscript
  PlanReviserTranscript
  ExecutorTranscript
  ReviewerTranscript
  RemediationTranscript
  HumanAnswers
  TaskBundle
  RejectionContext
  Skill
}

model AiRun {
  id                     String       @id @default(uuid())
  linearIssueId          String
  /// Human-readable key from Linear (e.g. ENG-42); distinct from internal UUID.
  linearIssueIdentifier  String?
  /// Snapshot of the issue body at run start (requirements for plan approval checks).
  linearIssueDescription String?
  linearIssueTitle       String?
  linearIssueUrl         String?
  repo                   String
  branchName             String?
  prNumber               Int?
  state                  RunState     @default(Todo)
  planVersion            Int          @default(0)
  approvedPlanVersion    Int?
  plannerRuntime         String?
  executorRuntime        String?
  reviewerRuntime        String?
  remediationRuntime     String?
  workingDirectory       String
  latestArtifactVersion  Int          @default(0)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  artifacts AiArtifact[]
  events    AiEvent[]

  @@map("ai_runs")
}

model AiArtifact {
  id          String       @id @default(uuid())
  runId       String
  type        ArtifactType
  version     Int
  payloadJson Json
  rawText     String
  createdAt   DateTime     @default(now())

  run AiRun @relation(fields: [runId], references: [id])

  @@index([runId, type])
  @@map("ai_artifacts")
}

model AiEvent {
  id          String   @id @default(uuid())
  runId       String
  eventType   String
  source      String
  payloadJson Json
  createdAt   DateTime @default(now())

  run AiRun @relation(fields: [runId], references: [id])

  @@index([runId])
  @@map("ai_events")
}

model ProcessedEvent {
  id              String   @id @default(uuid())
  source          String
  externalEventId String
  createdAt       DateTime @default(now())

  @@unique([source, externalEventId])
  @@map("processed_events")
}

model AgentSkill {
  id            String    @id @default(uuid())
  repoSlug      String
  taskCategory  String
  skillMarkdown String
  successCount  Int       @default(0)
  failureCount  Int       @default(0)
  utilityScore  Float     @default(0.0)
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime  @default(now())
  archivedAt    DateTime?

  @@index([repoSlug, archivedAt])
  @@index([repoSlug, utilityScore])
  @@map("agent_skills")
}
